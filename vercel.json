{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/terminal", "destination": "/index.html" },
    { "source": "/terminal/", "destination": "/index.html" },
    { "source": "/((?!terminal/fallback.json|og-image.svg|icon.svg).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/terminal/fallback.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=300" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
